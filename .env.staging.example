# ═══════════════════════════════════════════════════════
# CONFIGURACIÓN MONGODB
# ═══════════════════════════════════════════════════════
MONGODB_URI=mongodb://acdm_user:acdm_password_123@localhost:27018/acdm_db?authSource=acdm_db

# ═══════════════════════════════════════════════════════
# ENTORNO
# ═══════════════════════════════════════════════════════
NODE_ENV=development
PORT=5000

# ═══════════════════════════════════════════════════════
# AUTENTICACIÓN JWT
# ═══════════════════════════════════════════════════════
JWT_SECRET=your_super_secret_jwt_key_change_in_production_2024
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production_2024
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# ═══════════════════════════════════════════════════════
# ENCRIPTACIÓN Y CONTRASEÑAS
# ═══════════════════════════════════════════════════════
ENCRYPTION_KEY=your_encryption_key_32_characters_min_2024
BCRYPT_ROUNDS=10

# ═══════════════════════════════════════════════════════
# CORS
# ═══════════════════════════════════════════════════════
CORS_ORIGIN=http://localhost:3000,http://localhost:5000,http://127.0.0.1:3000,http://127.0.0.1:5000

# ═══════════════════════════════════════════════════════
# SEGURIDAD
# ═══════════════════════════════════════════════════════
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCK_BASE_MINUTES=15
LOGIN_LOCK_MAX_MINUTES=240
LOGIN_RESPONSE_DELAY_MS=400
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# ═══════════════════════════════════════════════════════
# EMAIL
# ═══════════════════════════════════════════════════════
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_password
EMAIL_FROM=noreply@acdm.local

# ═══════════════════════════════════════════════════════
# BACKUP
# ═══════════════════════════════════════════════════════
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/app/backups
